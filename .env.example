# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.

# Application name — used to name the output folder  (e.g. "TicketFlow" → out/ticketflow/)
# Each app gets its own folder so multiple demos can coexist under out/
APP_PRODUCT_NAME=MyApp

# Application URL to record
APP_URL=https://acl-rheem.vercel.app/

# Login credentials (required for LOGIN_TYPE=1; not used for LOGIN_TYPE=2)
APP_USERNAME=admin@acldigital.com
APP_PASSWORD=Password123

# LOGIN_TYPE=1  Fill APP_USERNAME + APP_PASSWORD into the login form (default)
# LOGIN_TYPE=2  Click a Quick Access option on the login screen — credentials
#               are fetched by the app, not by the automation. APP_USERNAME and
#               APP_PASSWORD are ignored. Set APP_QUICK_ACCESS_INDEX to select
#               which card to click (0-based, default 0).
LOGIN_TYPE=1
# APP_QUICK_ACCESS_INDEX=0

# Optional: full path to ffprobe binary if it's not on PATH
# FFPROBE_PATH=C:/ffmpeg/bin/ffprobe.exe

# ─────────────────────────────────────────────────────────────────────────────
# Video Template
# ─────────────────────────────────────────────────────────────────────────────
# 'modern_saas' (default) — dark background, glassmorphic UI, animated camera,
#                           animated opening title, feature pills closing card.
# 'enterprise'            — B-roll problem opening, white product screens,
#                           static camera, presenter overlay, benefit slide,
#                           presenter full-screen closing.
VIDEO_TEMPLATE=modern_saas

# ─────────────────────────────────────────────────────────────────────────────
# Screen Fit  (enterprise template only)
# ─────────────────────────────────────────────────────────────────────────────
# 'full' (default) — app screen fills the frame edge-to-edge
# 'fit'            — app screen inset with padding, rounded corners, dark border
SCREEN_FIT=full

# ─────────────────────────────────────────────────────────────────────────────
# Presenter / Avatar
# ─────────────────────────────────────────────────────────────────────────────
# Set to false to hide the presenter overlay on every product scene.
# Default: true (show the avatar)
SHOW_AVATAR=true

# D-ID API key — used to generate animated talking-head presenter frames.
# Sign up free at https://studio.d-id.com → Settings → API → Create API key
# After getting the key, run:  npm run presenter:generate
D_ID_API_KEY=

# GitHub — used to temporarily host the presenter image so D-ID can access it.
# D-ID requires a public HTTPS URL (base64 not accepted). The script uploads to
# a public GitHub repo via the Contents API (JSON PUT — works through proxies)
# and deletes the file automatically after D-ID finishes.
#
# GITHUB_TOKEN : Personal Access Token with public_repo scope.
#   Create at: GitHub → Settings → Developer Settings → Personal Access Tokens
#              → Tokens (classic) → Generate new token → tick public_repo
# GITHUB_REPO  : A PUBLIC repository you own, e.g. yourname/public-assets
GITHUB_TOKEN=
GITHUB_REPO=
